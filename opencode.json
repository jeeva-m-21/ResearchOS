{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "profile": "default",
        "region": "us-east-1"
      }
    }
  },
  "model": "amazon-bedrock/deepseek.v3.2",
  "default_agent": "orchestrator",
  "lsp": true,
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "node_modules/**",
      ".next/**",
      "dist/**",
      "build/**",
      "__pycache__/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      ".turbo/**"
    ]
  },
  "instructions": [
    "AGENTS.md",
    "docs/01-high-level-architecture.md",
    "docs/02-domain-model.md",
    "docs/03-database-schema.md",
    "docs/09-event-architecture.md",
    "docs/06-search-architecture.md",
    "docs/08-notebook-architecture.md",
    ".opencode/agents/orchestrator.md",
    "STATE.md"
  ],
  "references": {
    "sdk": {
      "path": "sdk/python",
      "description": "Use for Python SDK implementation"
    },
    "backend": {
      "path": "backend/src",
      "description": "Use for backend API and domain code"
    },
    "frontend": {
      "path": "frontend",
      "description": "Use for Next.js frontend implementation"
    },
    "docs": {
      "path": "docs",
      "description": "Architecture and design documentation"
    },
    "tests": {
      "path": "backend/tests",
      "description": "Backend test files"
    }
  },
  "permission": {
    "edit": {
      "*": "allow",
      "Dockerfile": "deny",
      "**/Dockerfile": "deny",
      ".dockerignore": "deny",
      "docker-compose*.yml": "deny",
      "compose*.yml": "deny",
      "helm/**": "deny",
      "infra/terraform/**": "deny",
      ".github/**": "deny"
    },
    "bash": {
      "*": "allow",
      "pip install*": "deny",
      "python -m pip install*": "deny",
      "uv pip install*": "deny",
      "poetry add*": "deny",
      "docker system prune*": "deny",
      "docker compose down -v*": "deny",
      "git reset --hard*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "rm -rf*": "deny"
    },
    "webfetch": "allow",
    "external_directory": "deny",
    "doom_loop": "deny"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "timeout": 30000
    },
    "postgres": {
      "type": "local",
      "command": ["uvx", "postgres-mcp", "--access-mode=restricted"],
      "environment": {
        "DATABASE_URI": "postgresql://researcher:password123@localhost:5432/researchos_dev"
      },
      "enabled": true,
      "timeout": 30000
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
      "timeout": 30000
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 30000
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": true,
      "timeout": 30000
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"],
      "enabled": true,
      "timeout": 30000
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "timeout": 30000
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
      "timeout": 30000
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true,
      "timeout": 30000
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true,
      "timeout": 30000
    },
    "docker": {
      "type": "local",
      "command": ["npx", "-y", "mcp-server-docker-npx"],
      "enabled": true,
      "timeout": 30000
    }
  }
}
