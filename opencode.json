{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "profile": "default",
        "region": "us-east-1"
      }
    }
  },
  "model": "amazon-bedrock/us.deepseek.v3.2",
  "default_agent": "orchestrator",
  "lsp": true,
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "node_modules/**",
      ".next/**",
      "dist/**",
      "build/**",
      "__pycache__/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      ".turbo/**"
    ]
  },
  "instructions": [
    "CLAUDE.md",
    "AGENTS.md",
    "docs/**/*.md"
  ],
  "permission": {
    "edit": {
      "*": "allow",
      "Dockerfile": "deny",
      "**/Dockerfile": "deny",
      ".dockerignore": "deny",
      "docker-compose*.yml": "deny",
      "compose*.yml": "deny",
      "helm/**": "deny",
      "infra/terraform/**": "deny",
      ".github/**": "deny",
      "backend/alembic/versions/**": "deny"
    },
    "bash": {
      "*": "allow",
      "pip install*": "deny",
      "python -m pip install*": "deny",
      "uv pip install*": "deny",
      "poetry add*": "deny",
      "docker system prune*": "deny",
      "docker compose down -v*": "deny",
      "git reset --hard*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "rm -rf*": "deny"
    },
    "webfetch": "allow",
    "external_directory": "deny",
    "doom_loop": "deny"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "timeout": 30000
    },
    "postgres": {
      "type": "local",
      "command": ["uvx", "postgres-mcp", "--access-mode=restricted"],
      "environment": {
        "DATABASE_URI": "postgresql://researcher:password123@localhost:5432/researchos_dev"
      },
      "enabled": true,
      "timeout": 30000
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
      "timeout": 30000
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 30000
    }
  }
}